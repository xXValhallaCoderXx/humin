# Copy to .env and fill in. .env is gitignored.

# --- Chat (extractor + judge) via OpenRouter ---
# One OpenAI-compatible API, many models. Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Per-role model slugs (any id from https://openrouter.ai/models). Override to
# orchestrate different models per stage.
# Other current slugs: openai/gpt-5.5 · google/gemini-3.5-flash ·
#   anthropic/claude-haiku-latest · deepseek/deepseek-v4-flash (cheaper judge/extractor options)
HUMIN_EXTRACT_MODEL=anthropic/claude-opus-4.8
HUMIN_JUDGE_MODEL=anthropic/claude-opus-4.8

# Optional: reasoning effort for reasoning-capable models (low|medium|high). Ignored otherwise.
# HUMIN_REASONING_EFFORT=medium

# Optional: attribution shown on the OpenRouter dashboard.
# HUMIN_APP_URL=https://your-app.example

# --- Embeddings (DIRECT provider — not available via OpenRouter) ---
# Only needed once Phase 1 uses vectors (e.g. semantic dedup). Phase 0 does not.
# HUMIN_EMBED_API_KEY=sk-...
# HUMIN_EMBED_BASE_URL=https://api.openai.com/v1
# HUMIN_EMBED_MODEL=text-embedding-3-small

# --- Identity ---
# Who counts as "the user" (the founder), used on import to set direction_hint
# (outbound = authored by the user, inbound = received). Comma-separated list of
# emails, display names, and chat handles the user sends from.
HUMIN_FOUNDER_IDENTITIES=you@example.com,Your Name,@yourhandle
